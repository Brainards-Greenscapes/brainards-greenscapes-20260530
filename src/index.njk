---
layout: layouts/base.njk
title: "Landscaping in Las Cruces, NM | Brainard's Greenscapes"
description: "Expert landscaping Las Cruces homeowners trust — xeriscaping, hardscaping, artificial turf, and irrigation built for the desert. Owner-operated, 19+ years. Free estimates."
pageJS: ['nav.js']
---

<!-- Hero -->
<section class="relative bg-green-950 text-white overflow-hidden">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-20 md:py-28 grid md:grid-cols-2 gap-12 items-center">
    <div>
      <p class="text-green-300 font-semibold text-sm uppercase tracking-wider mb-4">Owner-Operated. Locally Trusted.</p>
      <h1 class="font-heading text-5xl md:text-6xl lg:text-7xl font-bold leading-tight mb-6">
        Las Cruces<br>
        <span class="text-green-400">Landscaping Done Right</span><br>
        — Since 2007
      </h1>
      <p class="text-green-100 text-lg mb-8 max-w-lg">
        From water-smart yards to stone patios and full irrigation systems — everything your Las Cruces property needs to look great and hold up in the desert.
      </p>
      <div class="flex flex-col sm:flex-row gap-4">
        <a href="/contact/" class="inline-flex items-center justify-center px-8 py-3 bg-green-700 text-white font-semibold rounded-lg hover:bg-green-600 transition-colors">
          Schedule an Estimate
        </a>
        <a href="/portfolio/" class="inline-flex items-center justify-center px-8 py-3 border-2 border-green-400 text-green-300 font-semibold rounded-lg hover:bg-green-900 transition-colors">
          View Portfolio
        </a>
      </div>
    </div>
    <div class="relative">
      {% image "src/assets/images/brainards-stone-borders-1-a87271cb.webp", "Curving dry-stack stone border defining a planting bed in front of a Pueblo-style adobe home in Las Cruces", "rounded-2xl shadow-2xl", "eager", "high" %}
      <div class="absolute -bottom-4 -left-4 bg-green-700 text-white rounded-xl px-5 py-3 shadow-lg">
        <span class="font-heading font-bold text-2xl">19+</span>
        <span class="block text-sm text-green-100">Years of Excellence</span>
      </div>
    </div>
  </div>
</section>

<!-- Services -->
<section class="py-20 bg-white">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-14">
      <p class="text-green-700 font-semibold text-sm uppercase tracking-wider mb-2">Our Services</p>
      <h2 class="font-heading text-3xl md:text-4xl font-bold text-gray-900">What We Do</h2>
    </div>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-8">
      {% for service in services %}
      <a href="{{ service.url }}" class="group relative block bg-green-50 rounded-xl p-8 hover:bg-green-100 transition-colors overflow-hidden">
        <!-- Tree watermark -->
        <img src="/assets/images/BG_logo_tree_only.png" alt="" aria-hidden="true" class="absolute -bottom-6 -right-6 w-32 h-32 transition-opacity watermark" loading="lazy">
        <!-- Service icon -->
        <div class="w-12 h-12 bg-green-700 text-white rounded-lg flex items-center justify-center mb-4">
          {% if service.slug == "landscape-design" %}
          <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M9.53 16.122a3 3 0 00-5.78 1.128 2.25 2.25 0 01-2.4 2.245 4.5 4.5 0 008.4-2.245c0-.399-.078-.78-.22-1.128zm0 0a15.998 15.998 0 003.388-1.62m-5.043-.025a15.994 15.994 0 011.622-3.395m3.42 3.42a15.995 15.995 0 004.764-4.648l3.876-5.814a1.151 1.151 0 00-1.597-1.597L14.146 6.32a15.996 15.996 0 00-4.649 4.763m3.42 3.42a6.776 6.776 0 00-3.42-3.42"/></svg>
          {% elif service.slug == "landscaping" %}
          <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M12 3v2.25m6.364.386l-1.591 1.591M21 12h-2.25m-.386 6.364l-1.591-1.591M12 18.75V21m-4.773-4.227l-1.591 1.591M5.25 12H3m4.227-4.773L5.636 5.636M15.75 12a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0z"/></svg>
          {% elif service.slug == "hardscaping" %}
          <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6A2.25 2.25 0 016 3.75h2.25A2.25 2.25 0 0110.5 6v2.25a2.25 2.25 0 01-2.25 2.25H6a2.25 2.25 0 01-2.25-2.25V6zM3.75 15.75A2.25 2.25 0 016 13.5h2.25a2.25 2.25 0 012.25 2.25V18a2.25 2.25 0 01-2.25 2.25H6A2.25 2.25 0 013.75 18v-2.25zM13.5 6a2.25 2.25 0 012.25-2.25H18A2.25 2.25 0 0120.25 6v2.25A2.25 2.25 0 0118 10.5h-2.25a2.25 2.25 0 01-2.25-2.25V6zM13.5 15.75a2.25 2.25 0 012.25-2.25H18a2.25 2.25 0 012.25 2.25V18A2.25 2.25 0 0118 20.25h-2.25A2.25 2.25 0 0113.5 18v-2.25z"/></svg>
          {% elif service.slug == "xeriscaping" %}
          <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M12 21a9.004 9.004 0 008.716-6.747M12 21a9.004 9.004 0 01-8.716-6.747M12 21c2.485 0 4.5-4.03 4.5-9S14.485 3 12 3m0 18c-2.485 0-4.5-4.03-4.5-9S9.515 3 12 3m0 0a8.997 8.997 0 017.843 4.582M12 3a8.997 8.997 0 00-7.843 4.582m15.686 0A11.953 11.953 0 0112 10.5c-2.998 0-5.74-1.1-7.843-2.918m15.686 0A8.959 8.959 0 0121 12c0 .778-.099 1.533-.284 2.253m0 0A17.919 17.919 0 0112 16.5c-3.162 0-6.133-.815-8.716-2.247m0 0A9.015 9.015 0 013 12c0-1.605.42-3.113 1.157-4.418"/></svg>
          {% elif service.slug == "irrigation" %}
          <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M12 2.25c0 0-6.75 8.25-6.75 12.75a6.75 6.75 0 0013.5 0C18.75 10.5 12 2.25 12 2.25z"/></svg>
          {% elif service.slug == "landscape-maintenance" %}
          <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M11.42 15.17l-5.1-5.1a2.34 2.34 0 010-3.31l.71-.71a2.34 2.34 0 013.31 0l5.1 5.1M20.49 3.51a3.75 3.75 0 010 5.3L12 17.31l-5.3-5.3a3.75 3.75 0 015.3-5.3l.7.7.7-.7a3.75 3.75 0 015.3 0z"/></svg>
          {% endif %}
        </div>
        <h3 class="font-heading text-xl font-semibold text-green-900 mb-3 group-hover:text-green-700">{{ service.title }}</h3>
        <p class="text-gray-600 text-sm leading-relaxed mb-4">{{ service.description }}</p>
        <span class="text-green-700 text-sm font-medium">{{ service.linkText }} &rarr;</span>
      </a>
      {% endfor %}
    </div>
    <div class="text-center mt-10">
      <a href="/services/" class="inline-flex items-center px-8 py-3 bg-green-700 text-white font-semibold rounded-lg hover:bg-green-800 transition-colors">
        View All Services
      </a>
    </div>
  </div>
</section>

<!-- Process -->
<section class="py-20 bg-green-50">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-14">
      <p class="text-green-700 font-semibold text-sm uppercase tracking-wider mb-2">How It Works</p>
      <h2 class="font-heading text-3xl md:text-4xl font-bold text-gray-900">Our Process</h2>
    </div>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-8">
      <div class="text-center">
        <div class="w-14 h-14 bg-green-700 text-white rounded-full flex items-center justify-center mx-auto mb-4 font-heading font-bold text-xl">1</div>
        <h3 class="font-heading font-semibold text-lg mb-2">Free Property Visit</h3>
        <p class="text-gray-600 text-sm">David comes to you, looks at the lot, and talks through what you want the space to become.</p>
      </div>
      <div class="text-center">
        <div class="w-14 h-14 bg-green-700 text-white rounded-full flex items-center justify-center mx-auto mb-4 font-heading font-bold text-xl">2</div>
        <h3 class="font-heading font-semibold text-lg mb-2">Custom Plan & Pricing</h3>
        <p class="text-gray-600 text-sm">You get a detailed proposal — materials, labor, and timeline — tailored to your property and your budget.</p>
      </div>
      <div class="text-center">
        <div class="w-14 h-14 bg-green-700 text-white rounded-full flex items-center justify-center mx-auto mb-4 font-heading font-bold text-xl">3</div>
        <h3 class="font-heading font-semibold text-lg mb-2">Professional Build</h3>
        <p class="text-gray-600 text-sm">Our own crew does the work — earthwork, hardscape, plantings, and irrigation — on the schedule we agreed to.</p>
      </div>
      <div class="text-center">
        <div class="w-14 h-14 bg-green-700 text-white rounded-full flex items-center justify-center mx-auto mb-4 font-heading font-bold text-xl">4</div>
        <h3 class="font-heading font-semibold text-lg mb-2">We Stand Behind It</h3>
        <p class="text-gray-600 text-sm">Everything we install is covered by our workmanship guarantee. Optional maintenance plans keep it looking sharp long-term.</p>
      </div>
    </div>
  </div>
</section>

<!-- Stats -->
<section class="py-16 bg-green-800 text-white">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid grid-cols-2 md:grid-cols-4 gap-8 text-center">
      <div>
        <span class="font-heading text-4xl font-bold">500+</span>
        <span class="block text-green-100 text-sm mt-1">Projects Completed</span>
      </div>
      <div>
        <span class="font-heading text-4xl font-bold">19+</span>
        <span class="block text-green-100 text-sm mt-1">Years Experience</span>
      </div>
      <div>
        <span class="font-heading text-4xl font-bold">5/5</span>
        <span class="block text-green-100 text-sm mt-1">Average Rating</span>
      </div>
      <div>
        <span class="font-heading text-4xl font-bold">100%</span>
        <span class="block text-green-100 text-sm mt-1">Quality Guarantee</span>
      </div>
    </div>
  </div>
</section>

<!-- Testimonials -->
<section class="py-20 bg-white">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-14">
      <p class="text-green-700 font-semibold text-sm uppercase tracking-wider mb-2">Testimonials</p>
      <h2 class="font-heading text-3xl md:text-4xl font-bold text-gray-900">What Our Clients Say</h2>
    </div>
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
      {% for review in testimonials | batch(3) | first %}
      <div class="bg-green-50 rounded-xl p-8">
        <div class="flex gap-1 mb-4">
          {% for i in range(5) %}
          <svg class="w-5 h-5 text-green-600" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
          {% endfor %}
        </div>
        <blockquote class="text-gray-700 text-sm leading-relaxed mb-6">{{ review.text }}</blockquote>
        <div class="flex items-center justify-between">
          <div>
            <span class="font-semibold text-gray-900 text-sm">{{ review.name }}</span>
            <span class="block text-gray-500 text-xs">{{ review.date }}</span>
          </div>
          <a href="{{ review.googleUrl }}" aria-label="View on Google" rel="noopener" target="_blank" class="text-gray-400 hover:text-gray-600">
            <svg class="w-6 h-6" viewBox="0 0 24 24" fill="currentColor"><path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92a5.06 5.06 0 01-2.2 3.32v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.1z"/><path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"/><path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z"/><path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"/></svg>
          </a>
        </div>
      </div>
      {% endfor %}
    </div>
  </div>
</section>

<!-- Latest from the Blog -->
{% set latestPosts = collections.blog | reverse %}
{% if latestPosts.length > 0 %}
<section class="py-20 bg-white">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-14">
      <p class="text-green-700 font-semibold text-sm uppercase tracking-wider mb-2">Tips & Guides</p>
      <h2 class="font-heading text-3xl md:text-4xl font-bold text-gray-900">Latest from the Blog</h2>
      <p class="text-gray-600 mt-3 max-w-2xl mx-auto">Practical advice for Las Cruces homeowners — water savings, desert-smart landscaping, and seasonal tips.</p>
    </div>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-8">
      {% for post in latestPosts %}
        {% if loop.index0 < 3 %}
        <a href="{{ post.url }}" class="group relative block bg-white border border-gray-200 rounded-xl p-8 hover:border-green-300 hover:shadow-lg transition-all overflow-hidden">
          <img src="/assets/images/BG_logo_tree_only.png" alt="" aria-hidden="true" class="absolute -bottom-6 -right-6 w-32 h-32 transition-opacity watermark" loading="lazy">
          <time datetime="{{ post.date | date('iso') }}" class="text-sm text-gray-400">{{ post.date | date('readable') }}</time>
          <h3 class="font-heading text-xl font-semibold text-green-900 mt-2 mb-3 group-hover:text-green-700">{{ post.data.title }}</h3>
          <p class="text-gray-600 text-sm leading-relaxed mb-4">{{ post.data.excerpt }}</p>
          <span class="text-green-700 text-sm font-medium">Read more &rarr;</span>
        </a>
        {% endif %}
      {% endfor %}
    </div>
    <div class="text-center mt-10">
      <a href="/blog/" class="inline-flex items-center px-8 py-3 bg-green-700 text-white font-semibold rounded-lg hover:bg-green-800 transition-colors">
        View All Posts
      </a>
    </div>
  </div>
</section>
{% endif %}

<!-- FAQ -->
<section id="faq" class="py-20 bg-green-50">
  <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-14">
      <p class="text-green-700 font-semibold text-sm uppercase tracking-wider mb-2">FAQ</p>
      <h2 class="font-heading text-3xl md:text-4xl font-bold text-gray-900">Frequently Asked Questions</h2>
    </div>
    <div class="space-y-4">
      {% for item in faq %}
      <details class="group bg-white rounded-xl shadow-sm">
        <summary class="flex items-center justify-between p-6 cursor-pointer">
          <span class="font-heading font-medium text-gray-900">{{ item.question }}</span>
          <svg class="w-5 h-5 text-green-700 transition-transform group-open:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/>
          </svg>
        </summary>
        <div class="px-6 pb-6 text-gray-600 text-sm leading-relaxed">
          {{ item.answer }}
        </div>
      </details>
      {% endfor %}
    </div>
  </div>
</section>

<!-- Service Areas -->
<section class="py-20 bg-white">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 grid md:grid-cols-2 gap-12 items-center">
    <div>
      <p class="text-green-700 font-semibold text-sm uppercase tracking-wider mb-2">Service Areas</p>
      <h2 class="font-heading text-3xl md:text-4xl font-bold text-gray-900 mb-6">Las Cruces &amp; Doña Ana County</h2>
      <p class="text-gray-600 mb-6">Serving homeowners and commercial properties across Las Cruces and southern Doña Ana County.</p>
      <div class="grid grid-cols-2 gap-2 mb-8">
        <span class="text-sm text-gray-700">Las Cruces</span>
        <span class="text-sm text-gray-700">Mesilla</span>
        <span class="text-sm text-gray-700">Doña Ana</span>
        <span class="text-sm text-gray-700">Organ</span>
        <span class="text-sm text-gray-700">Anthony</span>
        <span class="text-sm text-gray-700">Sunland Park</span>
      </div>
      <a href="/service-areas/" class="inline-flex items-center px-6 py-3 bg-green-700 text-white font-semibold rounded-lg hover:bg-green-800 transition-colors">
        View All Service Areas
      </a>
    </div>
    <div>
      <iframe
        src="https://www.google.com/maps?q=Las%20Cruces+NM&output=embed"
        title="Map of Las Cruces, NM service area"
        width="100%" height="400"
        class="rounded-xl shadow-lg border-0"
        loading="lazy"
        referrerpolicy="no-referrer-when-downgrade"
        allowfullscreen>
      </iframe>
    </div>
  </div>
</section>

<!-- CTA Banner -->
{% include "partials/banner.njk" %}
