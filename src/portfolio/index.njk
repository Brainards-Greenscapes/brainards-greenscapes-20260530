---
layout: layouts/base.njk
title: "Portfolio | Brainard's Greenscapes Las Cruces"
description: "Browse before-and-after photos of landscaping, hardscaping, xeriscaping, and irrigation projects by Brainard's Greenscapes in Las Cruces, NM."
pageJS: ['portfolio-filter.js', 'before-after.js']
---

<!-- Hero -->
<section class="bg-green-950 text-white py-16">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
    <p class="text-green-300 font-semibold text-sm uppercase tracking-wider mb-4">Our Work</p>
    <h1 class="font-heading text-5xl md:text-6xl font-bold mb-4">Project Gallery</h1>
    <p class="text-green-100 text-lg max-w-2xl mx-auto">Real projects across Las Cruces and the Mesilla Valley. Every photo is work completed by our crew.</p>
  </div>
</section>

<!-- Gallery -->
<section class="py-16 bg-white">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">

    <!-- Filter tabs -->
    <div class="flex flex-wrap justify-center gap-3 mb-12" role="tablist" aria-label="Filter portfolio by category">
      <button class="px-5 py-2 rounded-full text-sm font-medium bg-green-700 text-white transition-colors" aria-selected="true" data-filter="all" role="tab" type="button">All</button>
      <button class="px-5 py-2 rounded-full text-sm font-medium bg-gray-100 text-gray-700 hover:bg-green-100 transition-colors" aria-selected="false" data-filter="landscaping" role="tab" type="button">Landscaping</button>
      <button class="px-5 py-2 rounded-full text-sm font-medium bg-gray-100 text-gray-700 hover:bg-green-100 transition-colors" aria-selected="false" data-filter="hardscaping" role="tab" type="button">Hardscaping</button>
      <button class="px-5 py-2 rounded-full text-sm font-medium bg-gray-100 text-gray-700 hover:bg-green-100 transition-colors" aria-selected="false" data-filter="xeriscaping" role="tab" type="button">Xeriscaping</button>
    </div>

    <!-- Image grid -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-5" data-portfolio-grid>
      {% for photo in gallery %}
      <div class="gallery-item group relative overflow-hidden rounded-xl cursor-pointer transition-all duration-300 hover:-translate-y-1.5 hover:shadow-xl" data-category="{{ photo.category }}">
        {% if loop.index0 == 0 %}
          {% image "src/assets/images/" + photo.src, photo.alt, "w-full h-64 object-cover transition-transform duration-300 group-hover:scale-105", "eager", "high" %}
        {% elif loop.index0 < 2 %}
          {% image "src/assets/images/" + photo.src, photo.alt, "w-full h-64 object-cover transition-transform duration-300 group-hover:scale-105", "eager" %}
        {% else %}
          {% image "src/assets/images/" + photo.src, photo.alt, "w-full h-64 object-cover transition-transform duration-300 group-hover:scale-105" %}
        {% endif %}
        <div class="absolute inset-0 bg-gradient-to-t from-black/60 via-transparent to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300">
          <div class="absolute bottom-0 left-0 right-0 p-4">
            <span class="inline-block px-3 py-1 bg-green-700/90 text-white text-xs font-medium rounded-full capitalize">{{ photo.category }}</span>
          </div>
        </div>
      </div>
      {% endfor %}
    </div>
  </div>
</section>

<!-- Before/After -->
<section class="py-16 bg-green-50">
  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-10">
      <h2 class="font-heading text-3xl font-bold text-gray-900 mb-3">Before & After</h2>
      <p class="text-gray-600">Drag the slider to see the transformation.</p>
    </div>
    <div class="relative rounded-xl overflow-hidden shadow-lg select-none cursor-ew-resize" data-before-after>
      <!-- After image (bottom layer) -->
      <img
        src="/assets/images/brainards-front-yard-after.webp"
        alt="After: finished front-yard xeriscape"
        width="1194" height="645"
        loading="lazy"
        draggable="false"
        class="block w-full"
      >
      <!-- Before image (top layer, absolutely positioned, same size) -->
      <img
        src="/assets/images/brainards-front-yard-before.webp"
        alt="Before: bare front yard with weeds and patchy dirt"
        width="1194" height="645"
        loading="lazy"
        draggable="false"
        class="absolute top-0 left-0 block w-full h-full object-cover"
        data-before-img
      >
      <!-- Slider line -->
      <div class="absolute top-0 bottom-0 w-0.5 bg-white pointer-events-none" data-before-line style="left: 50%;"></div>
      <!-- Knob -->
      <div class="absolute top-1/2 w-10 h-10 bg-white rounded-full shadow-lg flex items-center justify-center pointer-events-none" data-before-knob style="left: 50%; transform: translate(-50%, -50%);">
        <svg class="w-5 h-5 text-green-700" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7M9 5l7 7-7 7"/>
        </svg>
      </div>
      <!-- Labels -->
      <span class="absolute top-4 left-4 px-3 py-1 bg-black/50 text-white text-xs font-medium rounded-full pointer-events-none">Before</span>
      <span class="absolute top-4 right-4 px-3 py-1 bg-black/50 text-white text-xs font-medium rounded-full pointer-events-none">After</span>
    </div>
  </div>
</section>

{% include "partials/banner.njk" %}
