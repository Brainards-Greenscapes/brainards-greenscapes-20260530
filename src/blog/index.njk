---
layout: layouts/base.njk
title: "Landscaping Tips & Guides for Las Cruces | Brainard's Greenscapes Blog"
description: "Practical landscaping advice for Las Cruces homeowners — xeriscaping, water savings, irrigation tips, and desert-smart yard care from Brainard's Greenscapes."
---

<!-- Hero -->
<section class="bg-green-950 text-white py-16">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
    <p class="text-green-300 font-semibold text-sm uppercase tracking-wider mb-4">Tips & Guides</p>
    <h1 class="font-heading text-5xl md:text-6xl font-bold mb-4">The Brainard's Blog</h1>
    <p class="text-green-100 text-lg max-w-2xl mx-auto">Practical advice for keeping your Las Cruces property looking great — without fighting the desert.</p>
  </div>
</section>

<!-- Posts grid -->
<section class="py-16">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    {% set posts = collections.blog | reverse %}
    {% if posts.length > 0 %}
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-8">
      {% for post in posts %}
      <a href="{{ post.url }}" class="group relative block bg-white border border-gray-200 rounded-xl p-8 hover:border-green-300 hover:shadow-lg transition-all overflow-hidden">
        <img src="/assets/images/BG_logo_tree_only.png" alt="" aria-hidden="true" class="absolute -bottom-6 -right-6 w-32 h-32 transition-opacity watermark" loading="lazy">
        <time datetime="{{ post.date | date('iso') }}" class="text-sm text-gray-400">{{ post.date | date('readable') }}</time>
        <h2 class="font-heading text-xl font-semibold text-green-900 mt-2 mb-3 group-hover:text-green-700">{{ post.data.title }}</h2>
        <p class="text-gray-600 text-sm leading-relaxed mb-4">{{ post.data.excerpt }}</p>
        <span class="text-green-700 text-sm font-medium">Read more &rarr;</span>
      </a>
      {% endfor %}
    </div>
    {% else %}
    <div class="text-center py-12">
      <p class="text-gray-500 text-lg">Posts coming soon — check back shortly.</p>
    </div>
    {% endif %}
  </div>
</section>

{% include "partials/banner.njk" %}
