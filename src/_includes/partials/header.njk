<header class="bg-white shadow-sm sticky top-0 z-40 relative">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-24 md:h-28">

      <!-- Logo -->
      <a href="/" class="flex items-center gap-3" aria-label="{{ site.name }} — Home">
        <img src="/assets/images/logo-circle-nav.webp" alt="" width="72" height="72" class="rounded-full">
        <span class="font-heading font-bold text-2xl text-green-900 hidden sm:inline">{{ site.name }}</span>
      </a>

      <!-- Desktop nav -->
      <nav class="hidden md:flex items-center gap-8" aria-label="Main navigation">
        <div class="relative">
          <button type="button" class="flex items-center gap-1 text-lg font-medium text-gray-700 hover:text-green-700 transition-colors" data-mega-menu-toggle aria-expanded="false" aria-haspopup="true" aria-controls="services-mega-menu">
            Services
            <svg class="w-4 h-4 transition-transform duration-200" data-mega-menu-icon fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/>
            </svg>
          </button>
        </div>
        <a href="/portfolio/" class="text-lg font-medium text-gray-700 hover:text-green-700 transition-colors">Portfolio</a>
        <div class="relative">
          <button type="button" class="flex items-center gap-1 text-lg font-medium text-gray-700 hover:text-green-700 transition-colors" data-mega-menu-toggle aria-expanded="false" aria-haspopup="true" aria-controls="areas-mega-menu">
            Service Areas
            <svg class="w-4 h-4 transition-transform duration-200" data-mega-menu-icon fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/>
            </svg>
          </button>
        </div>
        <a href="/blog/" class="text-lg font-medium text-gray-700 hover:text-green-700 transition-colors">Blog</a>
        <a href="/about/" class="text-lg font-medium text-gray-700 hover:text-green-700 transition-colors">About</a>
        <a href="/contact/" class="inline-flex items-center px-6 py-2.5 bg-green-700 text-white text-lg font-semibold rounded-lg hover:bg-green-800 transition-colors">
          Free Estimate
        </a>
      </nav>

      <!-- Mobile menu button -->
      <button type="button" class="md:hidden p-2 text-gray-700" aria-label="Open menu" data-nav-toggle>
        <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16"/>
        </svg>
      </button>
    </div>
  </div>

  <!-- Services mega menu (desktop) -->
  <div id="services-mega-menu" class="hidden absolute top-full left-0 w-full bg-white border-t border-gray-100 shadow-xl z-50" data-mega-menu-panel>
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-10 grid grid-cols-2 md:grid-cols-3 xl:grid-cols-6 gap-8">
      {% for category in serviceNav %}
      <div>
        <p class="font-heading font-semibold text-green-900 mb-3">{{ category.title }}</p>
        {% if category.subpages.length %}
        <ul class="space-y-2 mb-3">
          {% for sub in category.subpages %}
          <li><a href="{{ sub.url }}" class="block text-sm text-gray-600 hover:text-green-700 transition-colors">{{ sub.title }}</a></li>
          {% endfor %}
        </ul>
        <a href="{{ category.url }}" class="block text-sm font-medium text-green-700 hover:text-green-800">All {{ category.title }} Services &rarr;</a>
        {% else %}
        <a href="{{ category.url }}" class="block text-sm font-medium text-green-700 hover:text-green-800">View {{ category.title }} &rarr;</a>
        {% endif %}
      </div>
      {% endfor %}
    </div>
  </div>

  <!-- Service Areas mega menu (desktop) -->
  <div id="areas-mega-menu" class="hidden absolute top-full left-0 w-full bg-white border-t border-gray-100 shadow-xl z-50" data-mega-menu-panel>
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8 grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 gap-x-6 gap-y-1">
      {% for area in serviceAreasSorted %}
      <a href="/service-areas/{{ area.slug }}/" class="block text-sm px-3 py-2 rounded-lg hover:bg-green-50 hover:text-green-700 transition-colors {% if area.name == 'Las Cruces' %}font-heading font-semibold text-green-900{% else %}text-gray-600{% endif %}">{{ area.name }}, {{ area.state }}</a>
      {% endfor %}
      <a href="/service-areas/" class="block text-sm font-medium text-green-700 hover:text-green-800 px-3 py-2">View All Service Areas &rarr;</a>
    </div>
  </div>

  <!-- Mobile nav -->
  <nav class="md:hidden hidden border-t border-gray-100" aria-label="Mobile navigation" data-nav-menu>
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pb-4">
      <div class="flex flex-col gap-2 pt-4">
        <div>
          <button type="button" class="w-full flex items-center justify-between px-3 py-2 text-gray-700 hover:bg-green-50 rounded-lg" data-mobile-accordion-toggle aria-expanded="false" aria-controls="mobile-services-panel">
            <span>Services</span>
            <svg class="w-4 h-4 transition-transform duration-200" data-mobile-accordion-icon fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/>
            </svg>
          </button>
          <div id="mobile-services-panel" class="hidden pl-3" data-mobile-accordion-panel>
            {% for category in serviceNav %}
            <div class="py-2 border-t border-gray-50 first:border-t-0">
              <a href="{{ category.url }}" class="block px-3 py-1.5 font-heading font-semibold text-green-900">{{ category.title }}</a>
              {% if category.subpages.length %}
              <div class="flex flex-col">
                {% for sub in category.subpages %}
                <a href="{{ sub.url }}" class="block px-6 py-1.5 text-sm text-gray-600 hover:bg-green-50 rounded-lg">{{ sub.title }}</a>
                {% endfor %}
              </div>
              {% endif %}
            </div>
            {% endfor %}
          </div>
        </div>
        <a href="/portfolio/" class="px-3 py-2 text-gray-700 hover:bg-green-50 rounded-lg">Portfolio</a>
        <div>
          <button type="button" class="w-full flex items-center justify-between px-3 py-2 text-gray-700 hover:bg-green-50 rounded-lg" data-mobile-accordion-toggle aria-expanded="false" aria-controls="mobile-areas-panel">
            <span>Service Areas</span>
            <svg class="w-4 h-4 transition-transform duration-200" data-mobile-accordion-icon fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/>
            </svg>
          </button>
          <div id="mobile-areas-panel" class="hidden pl-3" data-mobile-accordion-panel>
            {% for area in serviceAreasSorted %}
            <a href="/service-areas/{{ area.slug }}/" class="block px-3 py-1.5 text-sm rounded-lg hover:bg-green-50 {% if area.name == 'Las Cruces' %}font-semibold text-green-900{% else %}text-gray-600{% endif %}">{{ area.name }}, {{ area.state }}</a>
            {% endfor %}
          </div>
        </div>
        <a href="/blog/" class="px-3 py-2 text-gray-700 hover:bg-green-50 rounded-lg">Blog</a>
        <a href="/about/" class="px-3 py-2 text-gray-700 hover:bg-green-50 rounded-lg">About</a>
        <a href="/contact/" class="mt-2 text-center px-5 py-2.5 bg-green-700 text-white font-semibold rounded-lg hover:bg-green-800">
          Free Estimate
        </a>
      </div>
    </div>
  </nav>
</header>
