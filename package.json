{
  "name": "brainards-greenscapes",
  "version": "1.0.0",
  "description": "Brainard's Greenscapes — Las Cruces, NM landscaping website",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npx @tailwindcss/cli -i src/assets/css/input.css -o _site/assets/css/styles.css --watch\" \"npx @11ty/eleventy --serve\"",
    "build": "rm -rf _site && npx @tailwindcss/cli -i src/assets/css/input.css -o _site/assets/css/styles.css --minify && npx @11ty/eleventy",
    "clean": "rm -rf _site"
  },
  "devDependencies": {
    "@11ty/eleventy": "^3.0.0",
    "@11ty/eleventy-img": "^6.0.4",
    "@tailwindcss/cli": "^4.0.0",
    "@tailwindcss/typography": "^0.5.0",
    "autoprefixer": "^10.4.0",
    "concurrently": "^9.0.0",
    "markdown-it-anchor": "^9.2.0",
    "postcss": "^8.4.0",
    "tailwindcss": "^4.0.0"
  },
  "dependencies": {
    "@fontsource/bitter": "^5.2.10",
    "@fontsource/lato": "^5.2.7",
    "sharp": "^0.34.5"
  }
}
